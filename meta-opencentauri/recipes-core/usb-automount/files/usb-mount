#!/bin/sh
# /usr/local/bin/usb-mount
# Called by udev to mount/unmount USB storage partitions

copy_wpa_config() {
    SRC_DIR="$1"
    WPA_FILE="$SRC_DIR/wpa_supplicant.conf"

    if [ -f "$WPA_FILE" ]; then
        cp "$WPA_FILE" /etc/wpa_supplicant.conf || return 1
        rm "$WPA_FILE" || return 1
    fi
}

copy_gcode_files() {
    SRC_DIR="$1"

    # Moonraker/virtual_sdcard serve gcodes from /user-resource/gcodes
    # (/etc/klipper/gcodes is symlinked there). Files copied anywhere else are
    # not listed in the print interface (issues #158, #80).
    DEST_DIR="/user-resource/gcodes"
    mkdir -p "$DEST_DIR"

    COPIED=0
    for file in "$SRC_DIR"/*.gcode "$SRC_DIR"/*.gco "$SRC_DIR"/*.GCODE "$SRC_DIR"/*.GCO; do
        [ -f "$file" ] || continue
        BASENAME=$(basename "$file")
        [ -f "$DEST_DIR/$BASENAME" ] && continue

        if [ "$COPIED" -eq 0 ]; then
            uiprompt "Please wait" "Files from the USB are being copied to internal storage, please wait..."
            COPIED=1
        fi

        cp "$file" "$DEST_DIR/" || { uiclear; return 1; }
    done

    [ "$COPIED" -eq 1 ] && uiclear
}

install_firmware_update() {
    SRC_DIR="$1"
    SWU_FILE="$SRC_DIR/emergency.swu"
    SUCCESS_FILE="$SRC_DIR/emergency.swu.installed.success"
    FAILED_FILE="$SRC_DIR/emergency.swu.installed.failed"

    if [ ! -f "$SWU_FILE" ]; then
        return 0
    fi

    mv "$SWU_FILE" "$SRC_DIR/emergency.swu.installed" || return 1
    rm -f "$FAILED_FILE" "$SUCCESS_FILE"

    if strings "$SRC_DIR/emergency.swu.installed" | grep -qx "dsp0_partition"; then
        # Flash stock bootloader
        if ! restore-mcu-firmware; then
            echo "restore-mcu-firmware failed" > "$FAILED_FILE"
            return 1
        fi
    fi

    uiprompt "Installing firmware" "A firmware update is being installed, please wait..."

    if ! flash "$SRC_DIR/emergency.swu.installed"; then
        echo "flash failed" > "$FAILED_FILE"
        return 1
    fi

    if strings "$SRC_DIR/emergency.swu.installed" | grep -qx "dsp0_partition"; then
        # Revert stock bootcmd
        fw_setenv bootcmd "run setargs_mmc boot_dsp0 boot_normal"
    fi

    uiprompt "Firmware update complete" "Please reboot the printer to finalize the update."
    touch "$SUCCESS_FILE"
}

case "$1" in
    add)
        MOUNT_POINT="/tmp/usb/$2"
        mkdir -p "$MOUNT_POINT"
        mount "/dev/$2" "$MOUNT_POINT" -o rw,noexec,nosuid,nodev

        if mountpoint -q "$MOUNT_POINT"; then
            copy_wpa_config "$MOUNT_POINT"
            copy_gcode_files "$MOUNT_POINT"
            install_firmware_update "$MOUNT_POINT"
        fi
        ;;
    remove)
        MOUNT_POINT="/tmp/usb/$2"
        umount "$MOUNT_POINT" 2>/dev/null
        rmdir "$MOUNT_POINT" 2>/dev/null
        ;;
    *)
        echo "Usage: $0 {add|remove} <device>"
        exit 1
        ;;
esac
